# Server
PORT=3500
NODE_ENV=production
# Comma-separated if multiple (e.g. local dev + prod)
FRONTEND_URL=https://snapie.io,http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://user:pass@localhost:27017/snapieauth?authSource=admin
MONGODB_DB=snapieauth

# JWT (RS256)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_KEY_ID=snapie-auth-2026-01
# Session TTL in seconds. Default 7 days.
SESSION_TTL_SECONDS=604800

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Hive — the Snapie service account
SNAPIE_ACCOUNT=snapie
SNAPIE_ACTIVE_KEY=5J...
SNAPIE_POSTING_KEY=5K...
HIVE_NODES=https://api.hive.blog,https://api.deathwing.me,https://api.openhive.network
HIVE_NETWORK=mainnet

# Email (SMTP — tested with Resend)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=resend
EMAIL_PASS=
EMAIL_FROM=noreply@yourdomain.com
AUTH_BASE_URL=https://auth.snapie.io

# Payments — HIVE + Bitcoin Lightning (v4v.app), no KYC
# Hive account that receives payments (can be same as SNAPIE_ACCOUNT)
SNAPIE_RECEIVING_ACCOUNT=snapie
# Hive account registered with v4v.app for Lightning (defaults to SNAPIE_RECEIVING_ACCOUNT)
# SNAPIE_LIGHTNING_HIVE_ACCOUNT=snapie
# Currency v4v.app converts Lightning sats to: hive or hbd
V4V_RECEIVE_CURRENCY=hive
# How long to cache the witness account creation fee in ms (default: 10 min)
# ACCOUNT_FEE_CACHE_MS=600000

# RC delegation in billion RC units (min 5)
RC_DELEGATION_BN=5

# Free account creation limits (sponsor token bypasses both)
FREE_ACCOUNTS_PER_IP_PER_DAY=2
FREE_ACCOUNTS_GLOBAL_PER_DAY=10

# Custodial key encryption pepper — random 32-byte hex, never changes after first deploy
# Generate: openssl rand -hex 32
KEY_ENCRYPTION_PEPPER=

# Emancipation threshold in USD.
# When a custodial account's total value (HIVE + HBD + staked) reaches this amount,
# the user is forced to emancipate (take custody of their own keys) before continuing.
# Set to 0 to disable forced emancipation entirely (manual only).
EMANCIPATION_THRESHOLD_USD=25

# Hive price feed: coingecko | hive-internal
HIVE_PRICE_FEED=coingecko

# Account reconciliation interval in ms
ACCOUNT_RECONCILE_INTERVAL_MS=5000

# Internal API key — service-to-service auth for /api/internal/* endpoints
# Used by external apps (e.g. credit-earning app) to issue sponsor tokens and provision accounts.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=

# Admin bootstrap — comma-separated emails that are auto-granted isAdmin on login.
# These users gain access to /admin.html and all /api/admin/* endpoints.
# Once granted, admin status persists in the DB even if the email is removed from this list.
ADMIN_EMAILS=
